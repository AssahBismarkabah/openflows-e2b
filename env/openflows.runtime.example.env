# Runtime configuration for OpenFlows inside an E2B sandbox.
# Copy this to env/openflows.runtime.env locally, then fill real values.
# The TypeScript launch/start scripts upload it to /opt/openflows/.env.
# Do not commit a filled copy.

# OpenFlows CLI backend
DEFAULT_CLI=codex
CODEX_PROVIDER=openai
CODEX_PATH=codex

# OpenAI direct mode
# Direct OpenAI does not need OPENAI_BASE_URL.
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
LLM_PROVIDER=openai

# Optional. Used by parts of the LLM fallback stack.
LLM_FALLBACK=openai
MODEL_PROVIDER_MAP=gpt=openai,o1=openai,o3=openai,o4=openai
LLM_TIMEOUT_SECS=60
LLM_MAX_RETRIES=3
LLM_RETRY_DELAY_MS=1000

# GitHub target
# OpenFlows will clone this repo, read issues, create branches/PRs, poll CI,
# and merge approved PRs.
GITHUB_REPOSITORY=owner/repo
GITHUB_PERSONAL_ACCESS_TOKEN=ghp-your-token

# Optional per-agent GitHub tokens. If unset, the E2B launcher mirrors
# GITHUB_PERSONAL_ACCESS_TOKEN into these variables before starting OpenFlows.
# AGENT_NEXUS_GITHUB_TOKEN=ghp-nexus-token
# AGENT_FORGE_GITHUB_TOKEN=ghp-forge-token
# AGENT_SENTINEL_GITHUB_TOKEN=ghp-sentinel-token
# AGENT_VESSEL_GITHUB_TOKEN=ghp-vessel-token
# AGENT_LORE_GITHUB_TOKEN=ghp-lore-token

# Workspace and logging
AGENTFLOW_WORKSPACE_ROOT=/home/user/.agentflow/workspaces
RUST_LOG=info,agent_nexus=debug,agent_forge=debug,agent_vessel=debug,pocketflow_core=info

# Redis is not wired into binary/src/bin/agentflow.rs yet. Leave this unset
# unless the main agentflow entrypoint is updated to use SharedStore::new_redis.
# REDIS_URL=redis://localhost:6379
