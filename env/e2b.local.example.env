# Local operator configuration for scripts in this directory.
# Copy to .env.local if you want scripts to source it.
# Do not commit real credentials.

# E2B CLI template and sandbox commands need an access token.
# You can also run `e2b auth login` instead of setting this.
E2B_ACCESS_TOKEN=e2b-your-access-token

# E2B SDK/API calls use the API key. Keep it here for SDK-driven runs.
E2B_API_KEY=e2b-your-api-key

# Template name must be lowercase and contain only letters, numbers, dashes,
# and underscores.
E2B_TEMPLATE_NAME=openflows-codex-openai

# Template resources. OpenFlows builds and agent runs are heavier than a small
# script runner, so keep memory generous.
E2B_CPU_COUNT=4
E2B_MEMORY_MB=8192

# Long-lived runtime sandbox settings used by scripts/create-long-lived-sandbox.mjs.
# The SDK timeout is in milliseconds internally; we keep minutes in env for readability.
# Max continuous runtime depends on your E2B plan.
E2B_SANDBOX_TIMEOUT_MINUTES=60
E2B_SANDBOX_ON_TIMEOUT=pause
E2B_SANDBOX_AUTO_RESUME=true

# Local path to the OpenFlows checkout. Relative paths are resolved from this
# configuration repo root. The scripts also auto-detect common sibling checkout
# names, so this can usually stay commented.
# OPENFLOWS_REPO=../openflows
